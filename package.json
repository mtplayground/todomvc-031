{
  "name": "todomvc-031",
  "description": "TodoMVC implementation built with Vite, React, and TypeScript.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext .ts,.tsx",
